PORT=3001
MONGODB_URI=mongodb://username:password@host:27017/database?authSource=database
JWT_SECRET=change-me
SESSION_SECRET=change-me
CLIENT_ORIGIN=http://localhost:5173

# Firebase push notifications. Use one method only.
FIREBASE_SERVICE_ACCOUNT_BASE64=
# FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY_ID=
# FIREBASE_PRIVATE_KEY=

# Public URL used for uploaded notification images.
PUBLIC_API_BASE_URL=https://adminapi.example.com
APP_ASSET_BASE_URL=https://adminapi.example.com
